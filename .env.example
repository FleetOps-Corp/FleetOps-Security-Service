# =============================================================================
# FleetOps Security Cell — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the .env file with real credentials to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — Shared instance for auth_service and role_service
# -----------------------------------------------------------------------------
# Hostname of the PostgreSQL container (matches service name in docker-compose)
POSTGRES_HOST=postgres

# PostgreSQL port (default 5432)
POSTGRES_PORT=5432

# Name of the database to use
POSTGRES_DB=fleetops_security

# PostgreSQL superuser name (used to create the DB)
POSTGRES_USER=fleetops_user

# PostgreSQL password — use a strong random value in production
POSTGRES_PASSWORD=change_me_strong_password

# Full DSN used by SQLAlchemy (constructed from the values above)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://fleetops_user:change_me_strong_password@postgres:5432/fleetops_security

# Sync DSN used by Alembic migrations (alembic does not support asyncpg)
DATABASE_URL_SYNC=postgresql+psycopg2://fleetops_user:change_me_strong_password@postgres:5432/fleetops_security

# -----------------------------------------------------------------------------
# Redis — Cache for roles and session data
# -----------------------------------------------------------------------------
# Hostname of the Redis container (matches service name in docker-compose)
REDIS_HOST=redis

# Redis port (default 6379)
REDIS_PORT=6379

# Redis password — leave empty if Redis runs without authentication (dev only)
REDIS_PASSWORD=

# Time-to-live in seconds for cached role entries (default: 300 = 5 minutes)
REDIS_ROLE_CACHE_TTL=300

# Time-to-live in seconds for cached user session data (default: 3600 = 1 hour)
REDIS_SESSION_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# JWT — Token generation and validation
# -----------------------------------------------------------------------------
# Secret key used to sign JWT tokens — MUST be a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_jwt_secret_key_minimum_32_characters_long

# Hashing algorithm for JWT signature
JWT_ALGORITHM=HS256

# Token expiration time in minutes (SAD specifies 1 hour = 60 minutes)
JWT_EXPIRATION_MINUTES=60

# -----------------------------------------------------------------------------
# API Gateway — Internal service URLs and rate limiting
# -----------------------------------------------------------------------------
# Internal URL of the AuthService container
AUTH_SERVICE_URL=http://auth_service:8001

# Internal URL of the RoleService container
ROLE_SERVICE_URL=http://role_service:8002

# Rate limit: max requests per minute per user IP (SAD §7: efficiency tactic)
GATEWAY_RATE_LIMIT=60

# Port the API Gateway listens on
GATEWAY_PORT=8000

# -----------------------------------------------------------------------------
# AuthService
# -----------------------------------------------------------------------------
# Port the AuthService listens on (internal, not exposed externally)
AUTH_SERVICE_PORT=8001

# -----------------------------------------------------------------------------
# RoleService
# -----------------------------------------------------------------------------
# Port the RoleService listens on (internal, not exposed externally)
ROLE_SERVICE_PORT=8002

# -----------------------------------------------------------------------------
# Downstream microservice URLs — placeholders for other team services
# (SAD §3: Gateway holds the route dictionary for all microservices)
# Replace with actual URLs once other teams expose their services
# -----------------------------------------------------------------------------
VEHICLES_SERVICE_URL=http://vehicles_service:8010
ASSIGNMENTS_SERVICE_URL=http://assignments_service:8020
INCIDENTS_SERVICE_URL=http://incidents_service:8030
MAINTENANCE_SERVICE_URL=http://maintenance_service:8040
REPORTS_SERVICE_URL=http://reports_service:8050

# -----------------------------------------------------------------------------
# Application environment
# -----------------------------------------------------------------------------
# Set to "production" in production deployments
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# DockerHub username for pulling images in production
DOCKERHUB_USERNAME=tu_usuario